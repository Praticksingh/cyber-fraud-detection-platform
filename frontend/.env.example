# Environment Configuration Example
# 
# Default backend URL:
#   https://cyber-fraud-detection-platform.onrender.com
#
# For local development, override with:
#   http://localhost:8000

# API Base URL
REACT_APP_API_URL=https://cyber-fraud-detection-platform.onrender.com

# API Key — set this to the value of PUBLIC_API_KEY on your backend
REACT_APP_API_KEY=your-api-key-here
