# Environment
ENVIRONMENT=development

# API Keys — replace with your own strong, random values
PUBLIC_API_KEY=your-public-api-key-here
ADMIN_API_KEY=your-admin-api-key-here

# JWT Secret — replace with a long, random secret (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=your-jwt-secret-key-here

# Email Alert Settings
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=admin@example.com

# Webhook Alert Settings
ALERT_WEBHOOK_URL=https://your-webhook-url.com/alerts

# Database
DATABASE_URL=sqlite:///fraud.db

# Server
HOST=0.0.0.0
PORT=8000
